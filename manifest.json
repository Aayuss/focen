{
  "manifest_version": 3,
  "name": "Focen",
  "version": "1.0",
  "description": "Advanced website blocker and timer with strict rules.",
  "icons": {
    "16": "focen.png",
    "32": "focen.png",
    "48": "focen.png",
    "128": "focen.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Focen Settings",
    "default_popup": "popup/popup.html",
    "default_icon": "focen.png"
  }
}
